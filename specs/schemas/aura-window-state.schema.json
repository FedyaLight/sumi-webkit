{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aura.local/schemas/aura-window-state.schema.json",
  "title": "AuraWindowState",
  "type": "object",
  "required": [
    "schemaVersion",
    "windowId",
    "windowMode",
    "activeSpaceId",
    "collapsedPinnedSpaceIds",
    "selection",
    "expandedFolderIds",
    "compactModeState",
    "liveEssentials",
    "mediaCardsState",
    "mruTabIds",
    "splitStates"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "windowId": { "type": "string" },
    "windowMode": {
      "type": "string",
      "enum": ["standard", "blank"]
    },
    "activeSpaceId": { "type": "string" },
    "collapsedPinnedSpaceIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "selection": { "$ref": "#/$defs/selectionState" },
    "expandedFolderIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "compactModeState": { "$ref": "#/$defs/compactModeState" },
    "liveEssentials": {
      "type": "array",
      "items": { "$ref": "#/$defs/essentialInstance" }
    },
    "mediaCardsState": { "$ref": "#/$defs/mediaCardsState" },
    "mruTabIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "splitStates": {
      "type": "array",
      "items": { "$ref": "#/$defs/splitState" }
    },
    "glanceState": {
      "oneOf": [
        { "$ref": "#/$defs/glanceState" },
        { "type": "null" }
      ]
    }
  },
  "$defs": {
    "selectionState": {
      "type": "object",
      "required": ["kind", "activeSpaceId"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "none",
            "space",
            "emptySpaceSurface",
            "entryNode",
            "tab",
            "essential",
            "splitItem",
            "glance"
          ]
        },
        "activeSpaceId": { "type": "string" },
        "activeEmptySpaceSurfaceId": { "type": ["string", "null"] },
        "selectedEntryId": { "type": ["string", "null"] },
        "activeTabId": { "type": ["string", "null"] },
        "focusedSplitTabId": { "type": ["string", "null"] },
        "activeGlanceId": { "type": ["string", "null"] },
        "activeEssentialInstanceId": { "type": ["string", "null"] },
        "mostRecentTabId": { "type": ["string", "null"] }
      }
    },
    "compactModeState": {
      "type": "object",
      "required": [
        "enabled",
        "hideSidebar",
        "hideToolbar",
        "sidebarRevealed",
        "toolbarRevealed",
        "revealLockedByKeyboard",
        "hoverRevealEnabled",
        "hoverHideDelayMs",
        "flashPopupEnabled",
        "flashPopupDurationMs"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "hideSidebar": { "type": "boolean" },
        "hideToolbar": { "type": "boolean" },
        "sidebarRevealed": { "type": "boolean" },
        "toolbarRevealed": { "type": "boolean" },
        "revealLockedByKeyboard": { "type": "boolean" },
        "hoverRevealEnabled": { "type": "boolean" },
        "hoverHideDelayMs": { "type": "integer", "minimum": 0 },
        "flashPopupEnabled": { "type": "boolean" },
        "flashPopupDurationMs": { "type": "integer", "minimum": 0 }
      }
    },
    "essentialInstance": {
      "type": "object",
      "required": ["id", "launcherId", "attachedProfileId"],
      "properties": {
        "id": { "type": "string" },
        "launcherId": { "type": "string" },
        "attachedProfileId": { "type": "string" },
        "tabId": { "type": ["string", "null"] },
        "splitId": { "type": ["string", "null"] },
        "reservesLauncherSlot": { "type": "boolean" },
        "launcherSlotShowsSplitProxy": { "type": "boolean" },
        "detachedFromLauncher": { "type": "boolean" },
        "isLive": { "type": "boolean" }
      }
    },
    "mediaCardsState": {
      "type": "object",
      "required": ["dismissedPlaybackEpochIds"],
      "properties": {
        "dismissedPlaybackEpochIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "splitItem": {
      "type": "object",
      "required": ["tabId", "flex"],
      "properties": {
        "tabId": { "type": "string" },
        "flex": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "splitState": {
      "type": "object",
      "required": [
        "splitId",
        "groupId",
        "spaceId",
        "axis",
        "layoutPreset",
        "layoutTree",
        "headerControls",
        "showActiveOutline",
        "pinStatePropagatesAcrossGroup",
        "allowEmptySplitReplacement",
        "pinnedGroup",
        "hideInFullscreen"
      ],
      "properties": {
        "splitId": { "type": "string" },
        "groupId": { "type": "string" },
        "spaceId": { "type": "string" },
        "axis": {
          "type": "string",
          "enum": ["horizontal", "vertical"]
        },
        "layoutPreset": {
          "type": "string",
          "enum": ["grid", "vertical", "horizontal"]
        },
        "projectedItems": {
          "type": "array",
          "minItems": 2,
          "maxItems": 4,
          "items": { "$ref": "#/$defs/splitItem" }
        },
        "layoutTree": { "$ref": "#/$defs/splitLayoutNode" },
        "focusedTabId": { "type": ["string", "null"] },
        "folderParentId": { "type": ["string", "null"] },
        "headerControls": { "$ref": "#/$defs/splitHeaderControlsState" },
        "renderAsGroupedSidebarUnit": { "type": "boolean" },
        "sidebarGroupCollapsible": { "type": "boolean" },
        "moveAsSingleSidebarUnit": { "type": "boolean" },
        "showActiveOutline": { "type": "boolean" },
        "pinStatePropagatesAcrossGroup": { "type": "boolean" },
        "allowEmptySplitReplacement": { "type": "boolean" },
        "pinnedGroup": { "type": "boolean" },
        "hideInFullscreen": { "type": "boolean" }
      }
    },
    "splitLayoutNode": {
      "type": "object",
      "required": ["kind", "sizeInParent", "children"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["leaf", "row", "column"]
        },
        "sizeInParent": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "tabId": { "type": ["string", "null"] },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/splitLayoutNode" }
        }
      }
    },
    "splitHeaderControlsState": {
      "type": "object",
      "required": [
        "visibleOnHover",
        "showRearrangeButton",
        "showUnsplitButton"
      ],
      "properties": {
        "visibleOnHover": { "type": "boolean" },
        "showRearrangeButton": { "type": "boolean" },
        "showUnsplitButton": { "type": "boolean" }
      }
    },
    "glanceState": {
      "type": "object",
      "required": [
        "glanceId",
        "parentTabId",
        "previewTabId",
        "sourceUrl",
        "canPromoteToSplit",
        "expandedToFullTab",
        "visibleAcrossWorkspaceFiltering",
        "selectsPreviewWhenParentSelected",
        "closeRequiresFocusedConfirmation",
        "closeConfirmationTimeoutMs",
        "splitWithParentOnly",
        "reverseSplitOrderOnRightSidebar",
        "reduceMotionSkipsExpandAnimation"
      ],
      "properties": {
        "glanceId": { "type": "string" },
        "parentTabId": { "type": "string" },
        "previewTabId": { "type": "string" },
        "sourceUrl": { "type": "string" },
        "canPromoteToSplit": { "type": "boolean" },
        "expandedToFullTab": { "type": "boolean" },
        "visibleAcrossWorkspaceFiltering": { "type": "boolean" },
        "selectsPreviewWhenParentSelected": { "type": "boolean" },
        "hiddenFromSidebarCounts": { "type": "boolean" },
        "renderAsStandaloneSidebarEntry": { "type": "boolean" },
        "followsParentSpaceOnMove": { "type": "boolean" },
        "closeRequiresFocusedConfirmation": { "type": "boolean" },
        "closeConfirmationTimeoutMs": {
          "type": "integer",
          "minimum": 0
        },
        "splitWithParentOnly": { "type": "boolean" },
        "reverseSplitOrderOnRightSidebar": { "type": "boolean" },
        "reduceMotionSkipsExpandAnimation": { "type": "boolean" }
      }
    }
  }
}
