{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aura.local/schemas/aura-profile-state.schema.json",
  "title": "AuraProfileState",
  "type": "object",
  "required": [
    "schemaVersion",
    "profileId",
    "spaces",
    "workspaceThemes"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "profileId": { "type": "string" },
    "spaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/space" }
    },
    "workspaceThemes": {
      "type": "array",
      "items": { "$ref": "#/$defs/workspaceTheme" }
    }
  },
  "$defs": {
    "launcher": {
      "type": "object",
      "required": ["id", "kind", "title", "url"],
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["regular", "pinned", "essential"]
        },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "iconAsset": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "isLive": { "type": "boolean" },
        "resetToBaseUrlOnActivate": { "type": "boolean" }
      }
    },
    "entryNode": {
      "type": "object",
      "required": ["id", "kind", "title"],
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["launcher", "folder"]
        },
        "title": { "type": "string" },
        "folderIconAsset": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "launcher": {
          "oneOf": [
            { "$ref": "#/$defs/launcher" },
            { "type": "null" }
          ]
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/entryNode" }
        },
        "collapsed": { "type": "boolean" }
      }
    },
    "space": {
      "type": "object",
      "required": ["id", "name", "profileId", "pinnedEntries", "rootEntries"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "profileId": { "type": "string" },
        "iconAsset": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "pinnedEntries": {
          "type": "array",
          "items": { "$ref": "#/$defs/entryNode" }
        },
        "rootEntries": {
          "type": "array",
          "items": { "$ref": "#/$defs/entryNode" }
        }
      }
    },
    "workspaceTheme": {
      "type": "object",
      "required": [
        "spaceId",
        "primaryColorHex",
        "colorPoints",
        "algorithm",
        "opacity",
        "textureStrength",
        "monochrome"
      ],
      "properties": {
        "spaceId": { "type": "string" },
        "primaryColorHex": { "type": "string" },
        "colorPoints": {
          "type": "array",
          "maxItems": 3,
          "items": { "$ref": "#/$defs/workspaceThemeColorPoint" }
        },
        "presetSelection": {
          "oneOf": [
            { "$ref": "#/$defs/workspaceThemePresetSelection" },
            { "type": "null" }
          ]
        },
        "monochrome": { "type": "boolean" },
        "algorithm": {
          "type": "string",
          "enum": [
            "complementary",
            "splitComplementary",
            "analogous",
            "triadic",
            "floating"
          ]
        },
        "opacity": { "type": "number", "minimum": 0.3, "maximum": 0.9 },
        "textureStrength": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "multipleOf": 0.0625
        }
      }
    },
    "workspaceThemeColorPoint": {
      "type": "object",
      "required": ["id", "colorHex", "x", "y", "intensity"],
      "properties": {
        "id": { "type": "string" },
        "colorHex": { "type": "string" },
        "x": { "type": "number", "minimum": 0, "maximum": 1 },
        "y": { "type": "number", "minimum": 0, "maximum": 1 },
        "intensity": { "type": "number", "minimum": 0 }
      }
    },
    "workspaceThemePresetSelection": {
      "type": "object",
      "required": [
        "page",
        "presetId",
        "usesExplicitBlackWhitePage",
        "presetLightness"
      ],
      "properties": {
        "page": {
          "type": "string",
          "enum": [
            "lightFloating",
            "lightAnalogous",
            "darkFloating",
            "darkAnalogous",
            "blackWhite",
            "custom"
          ]
        },
        "presetId": { "type": "string" },
        "usesExplicitBlackWhitePage": { "type": "boolean" },
        "presetLightness": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    }
  }
}
