{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aura.local/schemas/aura-customization-bundle.schema.json",
  "title": "AuraCustomizationBundle",
  "type": "object",
  "required": [
    "schemaVersion",
    "bundleVersion",
    "globalState",
    "profiles"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "bundleVersion": { "type": "string" },
    "globalState": { "$ref": "#/$defs/globalState" },
    "profiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/profileState" }
    }
  },
  "$defs": {
    "launcher": {
      "type": "object",
      "required": ["id", "kind", "title", "url"],
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["regular", "pinned", "essential"]
        },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "iconAsset": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "isLive": { "type": "boolean" },
        "resetToBaseUrlOnActivate": { "type": "boolean" }
      }
    },
    "essentialLauncher": {
      "type": "object",
      "required": ["id", "kind", "title", "url"],
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["essential"]
        },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "iconAsset": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "isLive": { "type": "boolean" },
        "resetToBaseUrlOnActivate": { "type": "boolean" }
      }
    },
    "entryNode": {
      "type": "object",
      "required": ["id", "kind", "title"],
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["launcher", "folder"]
        },
        "title": { "type": "string" },
        "folderIconAsset": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "launcher": {
          "oneOf": [
            { "$ref": "#/$defs/launcher" },
            { "type": "null" }
          ]
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/entryNode" }
        },
        "collapsed": { "type": "boolean" }
      }
    },
    "space": {
      "type": "object",
      "required": ["id", "name", "profileId", "pinnedEntries", "rootEntries"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "profileId": { "type": "string" },
        "iconAsset": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "pinnedEntries": {
          "type": "array",
          "items": { "$ref": "#/$defs/entryNode" }
        },
        "rootEntries": {
          "type": "array",
          "items": { "$ref": "#/$defs/entryNode" }
        }
      }
    },
    "pinnedExtension": {
      "type": "object",
      "required": ["extensionId", "enabledForSite", "order"],
      "properties": {
        "extensionId": { "type": "string" },
        "enabledForSite": { "type": "boolean" },
        "order": { "type": "integer", "minimum": 0 }
      }
    },
    "workspaceThemeColorPoint": {
      "type": "object",
      "required": ["id", "colorHex", "x", "y", "intensity"],
      "properties": {
        "id": { "type": "string" },
        "colorHex": { "type": "string" },
        "x": { "type": "number", "minimum": 0, "maximum": 1 },
        "y": { "type": "number", "minimum": 0, "maximum": 1 },
        "intensity": { "type": "number", "minimum": 0 }
      }
    },
    "workspaceThemePresetSelection": {
      "type": "object",
      "required": [
        "page",
        "presetId",
        "usesExplicitBlackWhitePage",
        "presetLightness"
      ],
      "properties": {
        "page": {
          "type": "string",
          "enum": [
            "lightFloating",
            "lightAnalogous",
            "darkFloating",
            "darkAnalogous",
            "blackWhite",
            "custom"
          ]
        },
        "presetId": { "type": "string" },
        "usesExplicitBlackWhitePage": { "type": "boolean" },
        "presetLightness": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "workspaceTheme": {
      "type": "object",
      "required": [
        "spaceId",
        "primaryColorHex",
        "colorPoints",
        "algorithm",
        "opacity",
        "textureStrength",
        "monochrome"
      ],
      "properties": {
        "spaceId": { "type": "string" },
        "primaryColorHex": { "type": "string" },
        "colorPoints": {
          "type": "array",
          "maxItems": 3,
          "items": { "$ref": "#/$defs/workspaceThemeColorPoint" }
        },
        "presetSelection": {
          "oneOf": [
            { "$ref": "#/$defs/workspaceThemePresetSelection" },
            { "type": "null" }
          ]
        },
        "monochrome": { "type": "boolean" },
        "algorithm": {
          "type": "string",
          "enum": [
            "complementary",
            "splitComplementary",
            "analogous",
            "triadic",
            "floating"
          ]
        },
        "opacity": { "type": "number", "minimum": 0.3, "maximum": 0.9 },
        "textureStrength": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "multipleOf": 0.0625
        }
      }
    },
    "keyboardState": {
      "type": "object",
      "required": [
        "traversalMode",
        "shortcutsCustomizable",
        "numberingIncludesEssentials",
        "numberingIncludesPinned",
        "commandResultsHavePriority"
      ],
      "properties": {
        "traversalMode": {
          "type": "string",
          "enum": ["sequential", "mostRecentlyUsed"]
        },
        "shortcutsCustomizable": { "type": "boolean" },
        "numberingIncludesEssentials": { "type": "boolean" },
        "numberingIncludesPinned": { "type": "boolean" },
        "commandResultsHavePriority": { "type": "boolean" }
      }
    },
    "workspaceNavigationPreferences": {
      "type": "object",
      "required": [
        "wrapAroundNavigation",
        "openNewTabIfLastUnpinnedCloses"
      ],
      "properties": {
        "wrapAroundNavigation": { "type": "boolean" },
        "openNewTabIfLastUnpinnedCloses": { "type": "boolean" }
      }
    },
    "compactModePreferences": {
      "type": "object",
      "required": [
        "enabled",
        "hideSidebar",
        "hideToolbar",
        "hoverRevealEnabled",
        "hoverHideDelayMs",
        "flashPopupEnabled",
        "flashPopupDurationMs",
        "useThemedBackground"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "hideSidebar": { "type": "boolean" },
        "hideToolbar": { "type": "boolean" },
        "hoverRevealEnabled": { "type": "boolean" },
        "hoverHideDelayMs": { "type": "integer", "minimum": 0 },
        "flashPopupEnabled": { "type": "boolean" },
        "flashPopupDurationMs": { "type": "integer", "minimum": 0 },
        "useThemedBackground": { "type": "boolean" }
      }
    },
    "layoutPreferences": {
      "type": "object",
      "required": ["layoutMode", "tabsOnRight"],
      "properties": {
        "layoutMode": {
          "type": "string",
          "enum": ["singleToolbar", "multipleToolbar", "collapsedToolbar"]
        },
        "tabsOnRight": { "type": "boolean" }
      }
    },
    "urlBarPreferences": {
      "type": "object",
      "required": [
        "behaviorMode",
        "showCopyUrlButton",
        "showPictureInPictureButton",
        "showContextualIdentity"
      ],
      "properties": {
        "behaviorMode": {
          "type": "string",
          "enum": ["normal", "floatingOnType", "alwaysFloating"]
        },
        "showCopyUrlButton": {
          "type": "boolean"
        },
        "showPictureInPictureButton": {
          "type": "boolean"
        },
        "showContextualIdentity": {
          "type": "boolean"
        }
      }
    },
    "globalState": {
      "type": "object",
      "required": [
        "essentials",
        "keyboardState",
        "workspaceNavigationPreferences",
        "compactModePreferences",
        "layoutPreferences",
        "urlBarPreferences",
        "useAcrylicElements",
        "windowSchemeMode",
        "darkThemeStyle",
        "darkModeBias"
      ],
      "properties": {
        "essentials": {
          "type": "array",
          "items": { "$ref": "#/$defs/essentialLauncher" }
        },
        "keyboardState": { "$ref": "#/$defs/keyboardState" },
        "workspaceNavigationPreferences": {
          "$ref": "#/$defs/workspaceNavigationPreferences"
        },
        "compactModePreferences": {
          "$ref": "#/$defs/compactModePreferences"
        },
        "layoutPreferences": {
          "$ref": "#/$defs/layoutPreferences"
        },
        "urlBarPreferences": {
          "$ref": "#/$defs/urlBarPreferences"
        },
        "useAcrylicElements": {
          "type": "boolean"
        },
        "windowSchemeMode": {
          "type": "string",
          "enum": ["auto", "light", "dark"]
        },
        "darkThemeStyle": {
          "type": "string",
          "enum": ["default", "night", "colorful"]
        },
        "darkModeBias": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "profileState": {
      "type": "object",
      "required": [
        "schemaVersion",
        "profileId",
        "spaces",
        "workspaceThemes"
      ],
      "properties": {
        "schemaVersion": { "type": "integer", "minimum": 1 },
        "profileId": { "type": "string" },
        "spaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/space" }
        },
        "workspaceThemes": {
          "type": "array",
          "items": { "$ref": "#/$defs/workspaceTheme" }
        }
      }
    }
  }
}
